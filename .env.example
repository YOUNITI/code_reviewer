# Режим заглушки (true = работает без API-ключа, false = реальный LLM)
LLM_STUB_MODE=true

# API-ключ языковой модели (нужен только если LLM_STUB_MODE=false)
LLM_API_KEY=your_api_key_here

# URL API (по умолчанию OpenAI)
LLM_BASE_URL=https://api.openai.com/v1

# Название модели
LLM_MODEL=gpt-4o-mini

# Путь к базе данных
DATABASE_PATH=reviews.db

# Секретный ключ API
API_SECRET_KEY=dev-secret-key
